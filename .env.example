# Resend API key for the contact form. Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Email to forward contact submissions to. Defaults to julianmendon@gmail.com if unset.
CONTACT_TO_EMAIL=julianmendon@gmail.com

# The "from" address Resend uses to send. Must be a verified domain on your Resend account.
# During local dev you can use Resend's onboarding@resend.dev.
CONTACT_FROM_EMAIL=onboarding@resend.dev
